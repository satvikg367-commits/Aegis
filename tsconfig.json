{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true
  },
  "include": [
    "frontend/src/**/*",
    "frontend/vite.config.js",
    "backend/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "frontend/node_modules",
    "backend/node_modules",
    "frontend/dist",
    "backend/data"
  ]
}
